# Required: Tistory/Kakao login
KAKAO_EMAIL=you@example.com
KAKAO_PASSWORD="your-password"
TISTORY_BLOG=your-blog-name

# Required: OpenAI-compatible LLM provider
# Example Groq: https://api.groq.com/openai/v1
# Example OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your_api_key
OPENAI_MODEL=llama-3.3-70b-versatile

# Optional blog branding
BLOG_NAME=내 블로그
BLOG_AUTHOR_NAME=홍길동
BLOG_AUTHOR_ROLE=AI 활용 강사 · 디지털 워크플로 설계자
BLOG_AUTHOR_BIO=실무에서 바로 쓰는 AI 활용법을 쉽게 정리합니다.
BLOG_SITE_URL=https://example.com
BLOG_PHONE=010-0000-0000
BLOG_THUMBNAIL_URL=https://example.com/thumbnail.jpg
BLOG_CTA_TITLE=AI 실전 강의 안내
BLOG_CTA_TEXT=실무형 AI 강의와 컨설팅이 필요하시면 아래 링크로 문의하세요.
BLOG_CTA_BADGES=생성형AI 업무자동화,블로그 자동화,바이브코딩
BLOG_DEFAULT_VISIBILITY=public

# Optional: Blogger cross-posting
BLOGGER_ENABLED=false
BLOGGER_BLOG_ID=143884497314447653
BLOGGER_BLOG_URL=https://gpt-edu.blogspot.com/
